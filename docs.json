{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SolMarket",
  "colors": {
    "primary": "#9945FF",
    "light": "#14F195",
    "dark": "#9945FF",
    "background": {
      "dark": "#0A0A0F",
      "light": "#FFFFFF"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "how-it-works",
              "quickstart"
            ]
          },
          {
            "group": "Protocol",
            "pages": [
              "protocol/parimutuel",
              "protocol/smart-contract",
              "protocol/oracle",
              "protocol/fees"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/overview",
              "security/fund-safety",
              "security/transparency"
            ]
          }
        ]
      },
      {
        "tab": "$SOLMARKET Token",
        "groups": [
          {
            "group": "$SOLMARKET",
            "pages": [
              "token/overview",
              "token/tokenomics",
              "token/meteora",
              "token/buyback-burn"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Launch App",
          "href": "https://solmarket.app",
          "icon": "rocket"
        },
        {
          "anchor": "Twitter",
          "href": "https://x.com/SolMarket_Hub",
          "icon": "x-twitter"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Community",
        "href": "https://x.com/SolMarket_Hub"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://solmarket.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  },
  "rounded": "smooth",
  "footer": {
    "socials": {
      "x": "https://x.com/SolMarket_Hub"
    }
  }
}
